    <string name="dxwrapper_help_content"><![CDATA[
        <i><b>WineD3D</b></i> est une couche de traduction de DirectX 1-11 vers OpenGL.<br /><br />
        <i><b>DXVK</b></i> est une couche de traduction de Direct3D 9-11 vers Vulkan.<br /><br />
        <i><b>VKD3D</b></i> est une couche de traduction de l\'API Direct3D 12 vers Vulkan.<br /><br />
        <i><b>CNC DDraw</b></i> est une implémentation de DirectDraw pour une meilleure compatibilité avec les jeux classiques.
    ]]></string>
    <string name="box64_env_var_help__dynarec_safeflags" translatable="false"><![CDATA[
        Gestion des drapeaux sur les opcodes CALL/RET<br /><br />
        <b>0</b> : Traite CALL/RET comme s\'ils n\'avaient jamais besoin de drapeaux (plus rapide, instable)<br />
        <b>1</b> : La plupart des RET auront besoin de drapeaux, la plupart des CALL non<br />
        <b>2</b> : Tous les CALL/RET auront besoin de drapeaux (plus lent)
    ]]></string>
    <string name="box64_env_var_help__dynarec_fastnan" translatable="false">Génération de -NAN comme sur x86</string>
    <string name="box64_env_var_help__dynarec_fastround" translatable="false"><![CDATA[
        Génération d\'arrondi x86 précis<br /><br />
        <b>0</b> : Générer l\'arrondi float/double -> int comme sur x86<br />
        <b>1</b> : Ne pas traiter spécialement les cas limites d\'arrondi, pour aller le plus vite possible (pas de conversion INF/NAN/Overflow -> MIN_INT)<br />
        <b>2</b> : Tout ce qui est en 1, plus un arrondi rapide de double -> float (sans tenir compte du mode d\'arrondi actuel)
    ]]></string>
    <string name="box64_env_var_help__dynarec_x87double" translatable="false">Utilisation de Float/Double pour l\'émulation x87</string>
    <string name="box64_env_var_help__dynarec_bigblock" translatable="false"><![CDATA[
        Construction de grands blocs Dynarec<br /><br />
        <b>0</b> : Ne pas essayer de construire des blocs aussi grands que possible<br />
        <b>1</b> : Construire les blocs Dynarec aussi grands que possible<br />
        <b>2</b> : Construire des blocs Dynarec plus grands (continuer quand les blocs se chevauchent, mais uniquement pour les blocs en mémoire ELF)<br />
        <b>3</b> : Construire des blocs Dynarec plus grands (continuer quand les blocs se chevauchent, pour tous les types de mémoire)
    ]]></string>
    <string name="box64_env_var_help__dynarec_strongmem" translatable="false"><![CDATA[
        Simulation du modèle de mémoire stricte<br /><br />
        <b>0</b> : Ne rien faire de spécial<br />
        <b>1</b> : Activer certaines barrières mémoire lors de l\'écriture (sur certains opcodes MOV)<br />
        <b>2</b> : Tout ce qui est en 1, plus une barrière mémoire sur chaque écriture via MOV<br />
        <b>3</b> : Tout ce qui est en 2, plus une barrière lors de la lecture et sur certains opcodes SSE/SSE2
    ]]></string>
    <string name="box64_env_var_help__dynarec_weakbarrier" translatable="false"><![CDATA[
        Ajustement des barrières mémoire pour réduire l\'impact de strongmem sur les performances<br /><br />
        <b>0</b> : Utiliser des barrières sécurisées standard<br />
        <b>1</b> : Utiliser des barrières faibles pour de meilleures performances<br />
        <b>2</b> : Tout ce qui est en 1, plus la désactivation des dernières barrières d\'écriture
    ]]></string>
    <string name="box64_env_var_help__dynarec_forward" translatable="false">Définit la valeur forward maximale autorisée lors de la construction d\'un bloc</string>
    <string name="box64_env_var_help__dynarec_callret" translatable="false">Optimisation des opcodes CALL/RET</string>
    <string name="box64_env_var_help__dynarec_wait" translatable="false">Définit si Dynarec attendra que le FillBlock soit prêt</string>
    <string name="box64_env_var_help__dynarec_nativeflags" translatable="false">Le code généré utilisera les drapeaux natifs, si possible</string>
