    <string name="dxwrapper_help_content"><![CDATA[
        <i><b>WineD3D</b></i> es una capa de traducción de DirectX 1-11 a OpenGL.<br /><br />
        <i><b>DXVK</b></i> es una capa de traducción de Direct3D 9-11 a Vulkan.<br /><br />
        <i><b>VKD3D</b></i> es una capa de traducción de la API Direct3D 12 a Vulkan.<br /><br />
        <i><b>CNC DDraw</b></i> es una implementación de DirectDraw para mayor compatibilidad con juegos clásicos.
    ]]></string>
    <string name="box64_env_var_help__dynarec_safeflags" translatable="false"><![CDATA[
        Manejo de flags en opcodes CALL/RET<br /><br />
        <b>0</b> : Trata CALL/RET como si nunca necesitaran flags (más rápido, inestable)<br />
        <b>1</b> : La mayoría de RET necesitará flags, la mayoría de CALL no<br />
        <b>2</b> : Todos los CALL/RET necesitarán flags (más lento)
    ]]></string>
    <string name="box64_env_var_help__dynarec_fastnan" translatable="false">Generación de -NAN como en x86</string>
    <string name="box64_env_var_help__dynarec_fastround" translatable="false"><![CDATA[
        Generación de redondeo preciso x86<br /><br />
        <b>0</b> : Genera redondeo float/double -> int como en x86<br />
        <b>1</b> : No hace nada especial con los casos límite de redondeo (sin conversión INF/NAN/Overflow -> MIN_INT)<br />
        <b>2</b> : Todo lo de 1 más redondeo rápido de double -> float (sin tener en cuenta el modo de redondeo actual)
    ]]></string>
    <string name="box64_env_var_help__dynarec_x87double" translatable="false">Uso de Float/Double para la emulación x87</string>
    <string name="box64_env_var_help__dynarec_bigblock" translatable="false"><![CDATA[
        Construcción de bloques grandes en Dynarec<br /><br />
        <b>0</b> : No intenta construir bloques tan grandes como sea posible<br />
        <b>1</b> : Construye bloques Dynarec tan grandes como sea posible<br />
        <b>2</b> : Construye bloques más grandes (continúa cuando se solapan, solo para bloques en memoria elf)<br />
        <b>3</b> : Construye bloques más grandes (continúa cuando se solapan, para todos los tipos de memoria)
    ]]></string>
    <string name="box64_env_var_help__dynarec_strongmem" translatable="false"><![CDATA[
        Simulación del modelo de memoria fuerte<br /><br />
        <b>0</b> : No hace nada especial<br />
        <b>1</b> : Activa barreras de memoria al escribir (en algunos opcodes MOV)<br />
        <b>2</b> : Todo lo de 1 más una barrera de memoria en cada escritura con MOV<br />
        <b>3</b> : Todo lo de 2 más barreras al leer y en algunos opcodes SSE/SSE2
    ]]></string>
    <string name="box64_env_var_help__dynarec_weakbarrier" translatable="false"><![CDATA[
        Ajuste de barreras de memoria para reducir el impacto de strongmem en el rendimiento<br /><br />
        <b>0</b> : Usa barreras seguras normales<br />
        <b>1</b> : Usa barreras débiles para mayor rendimiento<br />
        <b>2</b> : Todo lo de 1 más desactivar las últimas barreras de escritura
    ]]></string>
    <string name="box64_env_var_help__dynarec_forward" translatable="false">Define el valor máximo de avance permitido al construir un bloque</string>
    <string name="box64_env_var_help__dynarec_callret" translatable="false">Optimización de opcodes CALL/RET</string>
    <string name="box64_env_var_help__dynarec_wait" translatable="false">Define si Dynarec esperará a que FillBlock esté listo</string>
    <string name="box64_env_var_help__dynarec_nativeflags" translatable="false">El código generado usará flags nativas cuando sea posible</string>
